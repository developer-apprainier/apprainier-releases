# macOS / IDE noise
.DS_Store
.AppleDouble
.LSOverride
.idea/
.vscode/

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.swp
*.swo

# Dependency caches and build outputs that should not be committed here
node_modules/
.dart_tool/
.packages
build/
dist/
coverage/

# Native build caches
.gradle/
.kotlin/
DerivedData/
*.xcarchive/

# Package-manager noise
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Release folders should track uploadable artifacts and docs, not expanded bundles.
v*/ios/*.xcframework/
v*/flutter/flutter_apprainier_plugin-*/
v*/reactnative/react-native-apprainier-plugin-*/
v*/web/apprainier-web-sdk-*/

# Keep packaged release artifacts tracked intentionally.
!*.aar
!*.zip
!*.tgz
